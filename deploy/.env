# ============================================
# sskodbox Docker Deployment Configuration
# ============================================

# --- Application ---
APP_PORT=8096
TIMEZONE=Asia/Shanghai

# --- Database ---
# Options: mysql, sqlite
DB_TYPE=mysql

# MySQL settings (used when DB_TYPE=mysql)
DB_HOST=db
DB_PORT=3306
DB_NAME=sskodbox
DB_USER=sskodbox
DB_PASS=sskodbox
DB_ROOT_PASS=root123

# --- Cache ---
# Options: file, redis
CACHE_TYPE=redis

# Redis settings (used when CACHE_TYPE=redis)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_AUTH=

# --- Admin Account (first-run setup) ---
ADMIN_USER=admin
ADMIN_PASS=Admin@123!
ADMIN_AUTO_PASS=0
# Set to 1 to auto-generate password (printed in logs on first run)
# ADMIN_AUTO_PASS=1

# Set to 1 to reset admin password (keeps existing data)
# ADMIN_RESET=1
